include README.md
include LICENSE
include requirements.txt

recursive-include judo *.py *.png *.jpg
recursive-include examples *.py *.feature *.json *.md
recursive-include assets/logos *.png *.jpg
recursive-include judo/assets/logos *.png *.jpg

global-exclude *.pyc
global-exclude __pycache__
global-exclude .DS_Store
global-exclude *.egg-info
global-exclude publish.py
global-exclude .git/
global-exclude .github/
global-exclude .vscode/
global-exclude .kiro/
global-exclude docs-site/
global-exclude judo_reports/
global-exclude test_output/
global-exclude test_reports/
global-exclude debug_output/
global-exclude dist/
